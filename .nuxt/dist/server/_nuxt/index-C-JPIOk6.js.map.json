;AAAA,MACE;AAAA,QACE,MAAM;AAAA,QACN,OAAO,EAAE,mBAAmB;AAAA,QAC5B,OAAO,EAAE,mBAAmB;AAAA,QAC5B,QAAQ;AAAA,MACZ;AAAA,MACE;AAAA,QACE,MAAM;AAAA,QACN,OAAO,EAAE,eAAe;AAAA,QACxB,OAAO,EAAE,oBAAoB;AAAA,QAC7B,QAAQ;AAAA,MACZ;AAAA,MACE;AAAA,QACE,MAAM;AAAA,QACN,OAAO;AAAA,QACP,OAAO,EAAE,kBAAkB;AAAA,QAC3B,QAAQ;AAAA,MACZ;AAAA,IACA,CAAC;;uBApDUJ,eAAAC,WAAA,EAAA,IAAG,YAAW,GAAA,MAAA,CAAA,kLAGaC,KAAAA,GAAE,iBAAA,CAAA,6CACzBA,KAAAA,GAAE,iBAAA,CAAA;oBAKYC,MAAA,UAAA,GAAU,CAArB,KAAK,MAAC;+FAGgB,IAAC,GAAA,IAAA,CAAA,4DAENC,eAAA,IAAI,IAAI,iDACPA,eAAA,IAAI,KAAK,8BAC5BA,eAAA,IAAI,KAAK,iDACWA,eAAA,IAAI,MAAM;;;;;;;;;;;;;;;;;ACU/C,UAAM,EAAE,EAAC,IAAK,QAAO;AAErB,UAAM,YAAY,SAAS,MAAM;AAAA,MAC/B,EAAE,MAAM,QAAQ,MAAM,YAAa,OAAO,EAAE,oBAAoB,GAAG,SAAS,GAAE;AAAA,MAC9E,EAAE,MAAM,QAAQ,MAAM,WAAa,OAAO,EAAE,oBAAoB,GAAG,SAAS,GAAE;AAAA,MAC9E,EAAE,MAAM,QAAQ,MAAM,YAAa,OAAO,EAAE,oBAAoB,GAAG,SAAS,GAAE;AAAA,MAC9E,EAAE,MAAM,QAAQ,MAAM,YAAa,OAAO,EAAE,oBAAoB,GAAG,SAAS,IAAG;AAAA,IACjF,CAAC;;uBAlCUJ,eAAAC,WAAA,EAAA,IAAG,YAAW,GAAA,MAAA,CAAA,kLAGaC,KAAAA,GAAE,iBAAA,CAAA,6CACzBA,KAAAA,GAAE,iBAAA,CAAA;oBAKaC,MAAA,SAAA,GAAS,CAArB,MAAM,MAAC;gGAGe,IAAC,GAAA,IAAA,CAAA,6DAELC,eAAA,KAAK,IAAI,iDACTA,eAAA,KAAK,IAAI,kDACRA,eAAA,KAAK,KAAK,kFAESE,eAAA,EAAA,OAAA,KAAK,UAAO,IAAA,CAAA;;;;;;;;;;;;;;;;;;uBClBzDN,eAAAC,WAAA,EAAA,IAAG,UAAA,GAAS,MAAA,CAAA,0NAKiBC,KAAAA,GAAE,eAAA,CAAA,6CACzBA,KAAAA,GAAE,eAAA,CAAA,2CACHA,KAAAA,GAAE,qBAAA,CAAA,oqCA8BiCA,KAAAA,GAAE,wBAAA,CAAA,0PAUlCA,KAAAA,GAAE,mBAAA,CAAA,2CACHA,KAAAA,GAAE,kBAAA,CAAA,+FAEHA,KAAAA,GAAE,iBAAA,CAAA,2LAKuBA,KAAAA,GAAE,qBAAA,CAAA,iGAGP,EAAA,SAAA,iBAAA,CAA4B,qFACvBA,KAAAA,GAAE,wBAAA,CAAA,iGAGP,EAAA,SAAA,kBAA4B,mFACvBA,KAAAA,GAAE,yBAAA,CAAA;;;;;;;;;;;;;;;ACnD5C,UAAM,EAAE,EAAC,IAAK,QAAO;AAErB,YAAQ;AAAA,MACN,OAAO;AAAA,MACP,MAAM;AAAA,QACJ,EAAE,MAAM,eAAe,SAAS,EAAE,UAAU,EAAC;AAAA,MACjD;AAAA,IACA,CAAC;;;;;;;;;;;;;;;;;;;;;;;;;","names":["_ssrRenderAttrs","_mergeProps","$t","_unref","_ssrInterpolate","_ssrRenderClass","_ssrRenderStyle"],"sources":["../../../../components/HeroSection.vue","../../../../components/SkillsSection.vue","../../../../components/ExperienceSection.vue","../../../../components/EducationSection.vue","../../../../components/LanguagesSection.vue","../../../../components/ContactSection.vue","../../../../pages/index.vue"],"sourcesContent":["<template>\n  <section id=\"hero\">\n    <div class=\"hero-bg-grid\" />\n    <div class=\"hero-orb hero-orb-1\" />\n    <div class=\"hero-orb hero-orb-2\" />\n\n    <!-- Left content -->\n    <div class=\"hero-content\">\n      <div class=\"hero-badge\">\n        <span class=\"badge-dot\" />\n        {{ $t('hero.badge') }}\n      </div>\n\n      <h1>\n        {{ $t('hero.title1') }}<br>\n        <span class=\"accent-line\">{{ $t('hero.title2') }}</span>\n      </h1>\n\n      <p class=\"hero-sub\">{{ $t('hero.sub') }}</p>\n\n      <div class=\"hero-cta\">\n        <a href=\"#experience\" class=\"btn-primary\">{{ $t('hero.cta_primary') }} →</a>\n        <a href=\"#contact\" class=\"btn-outline\">{{ $t('hero.cta_secondary') }}</a>\n      </div>\n    </div>\n\n    <!-- Right card -->\n    <div class=\"hero-visual\">\n      <div class=\"hero-card\">\n        <div class=\"hero-avatar-wrap\">\n          <div class=\"hero-avatar\">RI</div>\n          <div class=\"avatar-ring\" />\n        </div>\n        <div class=\"card-name\">Rabemiafara Ismael</div>\n        <div class=\"card-title\">FULL STACK DEVELOPER</div>\n        <div class=\"card-stats\">\n          <div class=\"stat-item\">\n            <div class=\"stat-num\">7+</div>\n            <div class=\"stat-label\">{{ $t('hero.years') }}</div>\n          </div>\n          <div class=\"stat-item\">\n            <div class=\"stat-num\">15+</div>\n            <div class=\"stat-label\">{{ $t('hero.projects') }}</div>\n          </div>\n          <div class=\"stat-item\">\n            <div class=\"stat-num\">6+</div>\n            <div class=\"stat-label\">{{ $t('hero.companies') }}</div>\n          </div>\n        </div>\n        <div class=\"card-tags\">\n          <span class=\"tag\">Laravel</span>\n          <span class=\"tag\">Vue.js</span>\n          <span class=\"tag purple\">Flutter</span>\n          <span class=\"tag purple\">NestJS</span>\n          <span class=\"tag amber\">Docker</span>\n          <span class=\"tag amber\">CI/CD</span>\n        </div>\n      </div>\n    </div>\n  </section>\n</template>\n\n<script setup>\n// No extra logic needed\n</script>\n\n<style scoped>\n#hero {\n  min-height: 100vh;\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  align-items: center;\n  padding: 8rem 3rem 4rem;\n  position: relative;\n  overflow: hidden;\n  gap: 3rem;\n}\n\n.hero-bg-grid {\n  position: absolute;\n  inset: 0;\n  background-image:\n    linear-gradient(rgba(0,229,255,0.03) 1px, transparent 1px),\n    linear-gradient(90deg, rgba(0,229,255,0.03) 1px, transparent 1px);\n  background-size: 60px 60px;\n  pointer-events: none;\n}\n\n.hero-orb {\n  position: absolute;\n  border-radius: 50%;\n  filter: blur(80px);\n  pointer-events: none;\n}\n.hero-orb-1 {\n  width: 500px; height: 500px;\n  background: radial-gradient(circle, rgba(0,229,255,0.12), transparent 70%);\n  top: -100px; right: 0;\n}\n.hero-orb-2 {\n  width: 300px; height: 300px;\n  background: radial-gradient(circle, rgba(124,58,237,0.12), transparent 70%);\n  bottom: 0; left: 30%;\n}\n\n/* ── Content ── */\n.hero-content {\n  position: relative;\n  z-index: 2;\n  animation: fadeUp 0.9s ease both;\n}\n\n.hero-badge {\n  display: inline-flex;\n  align-items: center;\n  gap: 0.5rem;\n  padding: 0.35rem 1rem;\n  background: rgba(0,229,255,0.08);\n  border: 1px solid rgba(0,229,255,0.2);\n  border-radius: 999px;\n  font-family: 'JetBrains Mono', monospace;\n  font-size: 0.72rem;\n  color: var(--accent);\n  letter-spacing: 0.08em;\n  margin-bottom: 2rem;\n}\n.badge-dot {\n  width: 6px; height: 6px;\n  border-radius: 50%;\n  background: var(--accent);\n  animation: pulse 2s infinite;\n}\n\nh1 {\n  font-family: 'Bebas Neue', sans-serif;\n  font-size: clamp(3.5rem, 7vw, 6.5rem);\n  line-height: 0.95;\n  letter-spacing: -0.01em;\n  margin-bottom: 1.5rem;\n}\n.accent-line { color: var(--accent); }\n\n.hero-sub {\n  font-size: 1.1rem;\n  color: var(--text2);\n  max-width: 480px;\n  margin-bottom: 2.5rem;\n  line-height: 1.7;\n}\n\n.hero-cta {\n  display: flex;\n  gap: 1rem;\n  flex-wrap: wrap;\n}\n\n/* ── Visual Card ── */\n.hero-visual {\n  position: relative;\n  z-index: 2;\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  animation: fadeUp 0.9s 0.2s ease both;\n  animation-fill-mode: both;\n}\n\n.hero-card {\n  background: var(--bg3);\n  border: 1px solid var(--border);\n  border-radius: 20px;\n  padding: 2.5rem;\n  width: 100%;\n  max-width: 380px;\n  position: relative;\n  box-shadow: var(--glow);\n  animation: float 6s ease-in-out infinite;\n}\n.hero-card::before {\n  content: '';\n  position: absolute;\n  inset: -1px;\n  border-radius: 21px;\n  background: linear-gradient(135deg, rgba(0,229,255,0.2), transparent 50%, rgba(124,58,237,0.2));\n  z-index: -1;\n}\n\n.hero-avatar-wrap {\n  position: relative;\n  width: 100px; height: 100px;\n  margin: 0 auto 1.5rem;\n}\n.hero-avatar {\n  width: 100px; height: 100px;\n  border-radius: 50%;\n  background: linear-gradient(135deg, var(--accent), var(--accent2));\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  font-family: 'Bebas Neue', sans-serif;\n  font-size: 2.5rem;\n  color: #fff;\n  letter-spacing: 0.05em;\n}\n.avatar-ring {\n  position: absolute;\n  inset: -6px;\n  border-radius: 50%;\n  border: 2px solid rgba(0,229,255,0.3);\n  animation: spin 8s linear infinite;\n}\n.avatar-ring::after {\n  content: '';\n  position: absolute;\n  top: -3px; left: 50%;\n  transform: translateX(-50%);\n  width: 8px; height: 8px;\n  border-radius: 50%;\n  background: var(--accent);\n}\n\n.card-name {\n  font-family: 'Bebas Neue', sans-serif;\n  font-size: 1.4rem;\n  letter-spacing: 0.05em;\n  text-align: center;\n  margin-bottom: 0.25rem;\n}\n.card-title {\n  font-size: 0.8rem;\n  color: var(--accent);\n  text-align: center;\n  letter-spacing: 0.08em;\n  font-family: 'JetBrains Mono', monospace;\n  margin-bottom: 1.5rem;\n}\n\n.card-stats {\n  display: grid;\n  grid-template-columns: repeat(3, 1fr);\n  gap: 0.5rem;\n  margin-bottom: 1.5rem;\n}\n.stat-item {\n  background: var(--surface);\n  border: 1px solid var(--border);\n  border-radius: 10px;\n  padding: 0.8rem 0.5rem;\n  text-align: center;\n}\n.stat-num {\n  font-family: 'Bebas Neue', sans-serif;\n  font-size: 1.5rem;\n  color: var(--accent);\n  line-height: 1;\n}\n.stat-label {\n  font-size: 0.6rem;\n  color: var(--text3);\n  letter-spacing: 0.06em;\n  text-transform: uppercase;\n  margin-top: 0.2rem;\n}\n\n.card-tags {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 0.4rem;\n  justify-content: center;\n}\n\n/* Tags (shared global ones via main.css, local overrides here if needed) */\n.tag {\n  padding: 0.25rem 0.7rem;\n  background: rgba(0,229,255,0.08);\n  border: 1px solid rgba(0,229,255,0.15);\n  border-radius: 999px;\n  font-size: 0.7rem;\n  color: var(--accent);\n  font-family: 'JetBrains Mono', monospace;\n}\n.tag.purple { background: rgba(124,58,237,0.08); border-color: rgba(124,58,237,0.2); color: #a78bfa; }\n.tag.amber  { background: rgba(245,158,11,0.08);  border-color: rgba(245,158,11,0.2);  color: #fbbf24; }\n\n/* ── Responsive ── */\n@media (max-width: 900px) {\n  #hero {\n    grid-template-columns: 1fr;\n    padding: 7rem 1.5rem 3rem;\n  }\n  .hero-visual { order: -1; }\n  h1 { font-size: 3.5rem; }\n  .hero-card { padding: 1.5rem; }\n}\n\n@keyframes fadeUp {\n  from { opacity: 0; transform: translateY(20px); }\n  to   { opacity: 1; transform: translateY(0); }\n}\n@keyframes pulse {\n  0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(0,229,255,0.4); }\n  50%       { opacity: 0.7; box-shadow: 0 0 0 6px rgba(0,229,255,0); }\n}\n@keyframes spin {\n  from { transform: rotate(0deg); }\n  to   { transform: rotate(360deg); }\n}\n@keyframes float {\n  0%, 100% { transform: translateY(0); }\n  50%       { transform: translateY(-10px); }\n}\n</style>\n","<template>\n  <section id=\"skills\">\n    <div class=\"section-inner\">\n      <div class=\"section-header scroll-fade\">\n        <div class=\"section-label\">{{ $t('skills.label') }}</div>\n        <h2>{{ $t('skills.title') }}</h2>\n      </div>\n\n      <div class=\"skills-grid\">\n        <div\n          v-for=\"(card, i) in skillCards\"\n          :key=\"card.title\"\n          class=\"skill-card scroll-fade\"\n          :style=\"{ transitionDelay: `${i * 0.08}s` }\"\n        >\n          <div class=\"skill-icon\">{{ card.icon }}</div>\n          <div class=\"skill-cat\">{{ card.cat }}</div>\n          <h3>{{ card.title }}</h3>\n          <div class=\"skill-items\">\n            <span v-for=\"item in card.items\" :key=\"item\" class=\"skill-item\">{{ item }}</span>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n</template>\n\n<script setup>\nconst { t } = useI18n()\n\nconst skillCards = computed(() => [\n  {\n    icon: '⚡',\n    cat: 'Frontend',\n    title: 'JavaScript Frameworks',\n    items: ['Vue.js', 'Nuxt.js', 'Ionic', 'Flutter', 'Node.js', 'NestJS'],\n  },\n  {\n    icon: '🐘',\n    cat: 'Backend',\n    title: 'PHP Frameworks',\n    items: ['Laravel', 'Symfony', 'Silex', 'API Platform', 'REST API'],\n  },\n  {\n    icon: '🗄️',\n    cat: t('skills.database'),\n    title: t('skills.data_infra'),\n    items: ['MySQL', 'MongoDB', 'Docker', 'CI/CD', 'Linux', 'Amazon S3'],\n  },\n  {\n    icon: '📱',\n    cat: t('skills.mobile'),\n    title: t('skills.mobile_platforms'),\n    items: ['Flutter', 'Ionic', 'WordPress', 'PrestaShop', 'PWA'],\n  },\n  {\n    icon: '🔧',\n    cat: t('skills.languages'),\n    title: t('skills.programming'),\n    items: ['PHP', 'JavaScript', 'Java', 'C / C++', 'Python', 'CSS'],\n  },\n  {\n    icon: '🎨',\n    cat: t('skills.design'),\n    title: t('skills.other'),\n    items: ['Photoshop', 'Illustrator'